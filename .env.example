# Copy to .env and fill in your key. The app reads the AI provider/model from here.

# --- Default AI provider: Gemini ---
AI_PROVIDER=gemini
GEMINI_API_KEY=your-key-here
AI_MODEL=gemini-3.5-flash
AI_VISION_MODEL=gemini-3.5-flash

# --- FREE online alternatives when Gemini quota runs out (no purchase needed) ---
# Any OpenAI-compatible endpoint works. Pick ONE block, comment out the Gemini
# lines above, and set AI_API_KEY + models.
#
# Groq (fast Llama models, generous free tier — recommended):
#   AI_PROVIDER=groq
#   AI_API_KEY=gsk_...              # free key from console.groq.com
#   AI_MODEL=openai/gpt-oss-120b
#   AI_MODEL_FALLBACKS=llama-3.3-70b-versatile,llama-3.1-8b-instant
#   AI_VISION_MODEL=qwen/qwen3.6-27b
# Free-tier daily quotas are PER MODEL — when one model's daily tokens run out,
# the provider automatically switches to the next model in AI_MODEL_FALLBACKS.
#
# OpenRouter (many ":free" models):
#   AI_PROVIDER=openrouter
#   AI_API_KEY=sk-or-...            # free key from openrouter.ai
#   AI_MODEL=meta-llama/llama-3.3-70b-instruct:free
#   AI_VISION_MODEL=qwen/qwen2.5-vl-72b-instruct:free
#
# Mistral La Plateforme (free tier):
#   AI_PROVIDER=mistral
#   AI_API_KEY=...                  # free key from console.mistral.ai
#   AI_MODEL=mistral-small-latest
#   AI_VISION_MODEL=pixtral-12b-latest
#
# Any other OpenAI-compatible server (incl. self-hosted):
#   AI_PROVIDER=openai-compat
#   AI_BASE_URL=https://your-endpoint/v1
#   AI_API_KEY=...

# Pipeline config
MAX_PAGES=10
CRAWL_TIMEOUT_MS=30000

# Boot seeding: on an EMPTY database the server scans these demo sites itself
# (real scans, never bundled data). Set SEED_URLS= (empty) to disable.
# SEED_URLS=https://example.com,https://namastedev.com

# Optional: Google Search Console (Phase 5, degrades gracefully if absent)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
